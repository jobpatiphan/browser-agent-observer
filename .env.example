# Copy to .env and tweak. run.sh / docker-compose load this automatically.
# Every value has a sane default — you usually don't need to change anything.

# --- dashboard backend ---
DASH_HOST=127.0.0.1        # interface the backend binds to
DASH_PORT=8790             # dashboard UI + websocket + HTTP API port

# host:port the addon/forwarder use to reach the backend (usually same box)
DASH_BACKEND=127.0.0.1:8790

# extra allowed websocket Origins (comma-separated), if you serve the UI
# from another host/port. Loopback on DASH_PORT is always allowed.
# DASH_ALLOWED_ORIGINS=http://192.168.1.10:8790

# --- traffic proxy (mitmproxy) ---
PROXY_HOST=127.0.0.1
PROXY_PORT=8083            # point your browser's --proxy-server here

# --- the browser the agent drives ---
# CDP (remote debugging) endpoint. The forwarder screencasts whatever page
# target it finds here. Launch your browser with --remote-debugging-port to match.
CDP_URL=http://localhost:9222

# --- security auditing / hardening (all optional) ---
# Only capture traffic to these hosts (comma-separated globs). Empty = all.
# SCOPE_HOSTS=*.target.com,10.0.0.*

# Shared-token gate on the HTTP API + websockets. Set this whenever the
# dashboard binds beyond loopback (the API can replay/drive real requests).
# Open the UI as http://host:8790/?token=YOUR_TOKEN
# DASH_TOKEN=change-me

# Append each session's events to JSONL here so it can be reopened later
# (GET /sessions). Unset = in-memory only.
# PERSIST_DIR=./sessions

# run.sh up auto-opens the dashboard; set 0 for headless/CI.
# OPEN_DASH=1
